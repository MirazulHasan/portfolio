# Required for all environments
DATABASE_URL="file:./dev.db"

# NextAuth – generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-this-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# === PRODUCTION (Vercel / Railway / etc.) ===
# Replace DATABASE_URL with your production database connection string.
# For PostgreSQL on Railway:
#   DATABASE_URL="postgresql://user:password@host:port/dbname"
# For Neon:
#   DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
#
# Set NEXTAUTH_URL to your deployed domain:
#   NEXTAUTH_URL="https://your-portfolio.vercel.app"
